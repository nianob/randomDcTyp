// This is a temlate for the config.json file.
// You probably want to copy it to config.json and adjust the settings to your needs.
// All values that are 'null' are can be adjusted. If you leave them null,
// some associated commands will be disabled. You can also leave out those options.
{
    "owner": 0, // the user ID of the Owner of the bot
    "dedicatedServer": null, // the server ID, the bot is dedicated to
    "ownerRole": null, // the Role ID of the Owner Role
    "pointBringingVcs": null, // list of all talks, that can bring Vc Points
    "altRole": null, // the ID of the role for alt accounts
    "afkChannel": null, // the ID of AFK Channel
    "aiModel": null, // the AI to use in ollama
    "disabled": null // if the bot is disabled and shouldnt start. Defaults to false
}